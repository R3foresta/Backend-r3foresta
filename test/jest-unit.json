{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "watchman": false,
  "testMatch": [
    "<rootDir>/src/**/*.spec.ts",
    "<rootDir>/test/unit/**/*.spec.ts"
  ],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": [
    "src/**/*.(t|j)s"
  ],
  "coverageDirectory": "<rootDir>/coverage/unit",
  "testTimeout": 15000
}
